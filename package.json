{
  "name": "video-bulk-downloader",
  "version": "0.1.0",
  "private": true,
  "description": "Bulk-download videos from a TikTok/Douyin/Bilibili/YouTube channel or single-video URL.",
  "main": "electron/dist/main.cjs",
  "scripts": {
    "setup": "node scripts/fetch-binaries.mjs",
    "build:f2": "node scripts/build-f2.mjs",
    "dev": "pnpm --parallel --filter @vbd/server --filter @vbd/web dev",
    "dev:server": "pnpm --filter @vbd/server dev",
    "dev:web": "pnpm --filter @vbd/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck && tsc -p electron/tsconfig.json",
    "app:build": "pnpm --filter @vbd/web build && node electron/build.mjs",
    "app:rebuild": "electron-rebuild -f -o better-sqlite3",
    "app": "pnpm app:build && electron .",
    "dist": "pnpm app:build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "rebuild:node": "pnpm rebuild better-sqlite3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/node": "^22.10.2",
    "@vbd/server": "workspace:*",
    "@vbd/shared": "workspace:*",
    "cross-env": "^7.0.3",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.6.3"
  }
}
